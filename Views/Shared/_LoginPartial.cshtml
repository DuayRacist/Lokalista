@using Microsoft.AspNetCore.Identity
@inject SignInManager<IdentityUser> SignInManager
@inject UserManager<IdentityUser> UserManager

<style>
    /* Earthy login partial styles - matching LokaLista palette
           Colors: #6B3A2A (buttons/CTAs), #C47D3E (highlights/hover),
           #4A7C59 (badges/success), #EB8B6D (puntos/icons),
           #F5ECD7 (bg), #3D2B1F (text) */

    .navbar-nav.earth-login-partial {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        margin-left: auto;
    }

    /* Cart button & badge styling */
    .cart-link {
        position: relative;
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(107, 58, 42, 0.12);
        padding: 0.4rem 1rem;
        border-radius: 48px;
        transition: all 0.2s ease;
        text-decoration: none;
    }

        .cart-link:hover {
            background-color: #6B3A2A;
            transform: translateY(-2px);
        }

            .cart-link:hover .cart-icon {
                color: #F5ECD7 !important;
            }

            .cart-link:hover #cartCount {
                background-color: #EB8B6D;
                color: #3D2B1F;
                transform: scale(1.05);
            }

    .cart-icon {
        font-size: 1.2rem;
        color: #EB8B6D !important;
        transition: color 0.2s;
    }

    #cartCount {
        background-color: #EB8B6D !important;
        color: #3D2B1F !important;
        border-radius: 40px;
        padding: 0.25rem 0.6rem;
        font-size: 0.7rem;
        font-weight: 700;
        transition: all 0.2s;
        border: none;
    }

    /* User greeting & profile link */
    .user-greeting {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(196, 125, 62, 0.12);
        padding: 0.4rem 1.2rem;
        border-radius: 48px;
        transition: all 0.2s;
        text-decoration: none;
    }

        .user-greeting:hover {
            background-color: #C47D3E;
            transform: translateY(-2px);
        }

            .user-greeting:hover .user-name,
            .user-greeting:hover .user-role,
            .user-greeting:hover .greeting-icon {
                color: #3D2B1F !important;
            }

    .greeting-icon {
        font-size: 1rem;
        color: #EB8B6D;
    }

    .user-name {
        font-weight: 600;
        color: #F5ECD7;
        text-decoration: none;
    }

    .user-role {
        font-size: 0.7rem;
        background-color: #4A7C59;
        color: #F5ECD7;
        padding: 0.15rem 0.5rem;
        border-radius: 40px;
        margin-left: 0.25rem;
        font-weight: 500;
    }

    /* Logout button */
    .logout-btn {
        background: transparent;
        border: none;
        padding: 0.4rem 1.2rem;
        border-radius: 48px;
        font-weight: 500;
        transition: all 0.2s;
        cursor: pointer;
        color: #F5ECD7 !important;
    }

        .logout-btn:hover {
            background-color: #6B3A2A;
            transform: translateY(-2px);
            box-shadow: 0 4px 12px rgba(107, 58, 42, 0.3);
            color: #F5ECD7 !important;
        }

    /* Register & Login links - WHITE FONT */
    .auth-link {
        padding: 0.4rem 1.2rem;
        border-radius: 48px;
        font-weight: 500;
        transition: all 0.2s;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        color: #FFFFFF !important; /* White font for Register & Login */
    }

        .auth-link.register {
            background: rgba(107, 58, 42, 0.15);
            color: #FFFFFF !important;
        }

            .auth-link.register:hover {
                background-color: #6B3A2A;
                transform: translateY(-2px);
                color: #FFFFFF !important;
            }

        .auth-link.login {
            background-color: #6B3A2A;
            color: #FFFFFF !important;
        }

            .auth-link.login:hover {
                background-color: #C47D3E;
                transform: translateY(-2px);
                box-shadow: 0 4px 12px rgba(196, 125, 62, 0.3);
                color: #FFFFFF !important;
            }

        /* Ensure icons inside auth links also have white color */
        .auth-link i {
            color: #FFFFFF !important;
        }

        .auth-link:hover i {
            color: #FFFFFF !important;
        }

    /* Text color overrides for dark navbar */
    .text-white-custom {
        color: #F5ECD7 !important;
    }

    /* Animation-free transitions */
    .cart-link, .user-greeting, .logout-btn, .auth-link {
        transition: all 0.2s ease;
    }

        /* Additional white text for any other elements */
        .logout-btn i {
            color: #F5ECD7 !important;
        }

        .logout-btn:hover i {
            color: #F5ECD7 !important;
        }
</style>

<ul class="navbar-nav earth-login-partial">
    <!-- Cart Button with Badge - Warm Earth Style -->
    <li class="nav-item">
        <a class="cart-link" href="/Cart/GetUserCart">
            <span id="cartCount" class="badge">0</span>
            <i class="bi bi-cart cart-icon"></i>
        </a>
    </li>

    @if (SignInManager.IsSignedIn(User))
    {
        <!-- User Greeting & Profile Link -->
        <li class="nav-item">
            <a class="user-greeting" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                <i class="bi bi-person-circle greeting-icon"></i>
                <span class="user-name">@User.Identity?.Name!</span>
                @if (User.IsInRole("Admin"))
                {
                    <span class="user-role">Admin</span>
                }
            </a>
        </li>

        <!-- Logout Button -->
        <li class="nav-item">
            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                <button type="submit" class="logout-btn nav-link">
                    <i class="bi bi-box-arrow-right"></i> Logout
                </button>
            </form>
        </li>
    }
    else
    {
        <!-- Register & Login Links for unauthenticated users - WHITE FONT -->
        <li class="nav-item">
            <a class="auth-link register" asp-area="Identity" asp-page="/Account/Register">
                <i class="bi bi-person-plus"></i> Register
            </a>
        </li>
        <li class="nav-item">
            <a class="auth-link login" asp-area="Identity" asp-page="/Account/Login">
                <i class="bi bi-key"></i> Login
            </a>
        </li>
    }
</ul>

<!-- Optional script to ensure cart count styling persists after dynamic updates -->
<script>
    // Preserve original cart count functionality while adding earth styling
    (function() {
        const originalLoadCartCount = window.loadCartCount;
        if (originalLoadCartCount) {
            window.loadCartCount = async function() {
                await originalLoadCartCount();
                // Additional styling class ensures badge maintains earthy look
                const cartBadge = document.getElementById('cartCount');
                if (cartBadge) {
                    cartBadge.classList.add('badge');
                }
            };
        }
    })();
</script>