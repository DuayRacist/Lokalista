@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<style>
    /* Earthy Error Page Styling - LokaLista Palette
           Colors: #6B3A2A (buttons/headers/CTAs), #C47D3E (highlights/hover),
           #4A7C59 (badges/success), #EB8B6D (puntos/icons),
           #F5ECD7 (page bg/cards/containers), #3D2B1F (text/navbar) */

    .error-container {
        max-width: 800px;
        margin: 2rem auto;
        padding: 2rem;
        background-color: #FFFFFF;
        border-radius: 32px;
        box-shadow: 0 12px 28px rgba(61, 43, 31, 0.08);
        transition: all 0.2s ease;
    }

        .error-container:hover {
            box-shadow: 0 20px 32px rgba(61, 43, 31, 0.12);
            transform: translateY(-2px);
        }

    .error-icon {
        text-align: center;
        margin-bottom: 1.5rem;
    }

        .error-icon i {
            font-size: 4rem;
            color: #EB8B6D;
            filter: drop-shadow(0 4px 8px rgba(235, 139, 109, 0.2));
        }

    .error-title {
        font-size: 2.5rem;
        font-weight: 700;
        background: linear-gradient(135deg, #6B3A2A 0%, #C47D3E 100%);
        background-clip: text;
        -webkit-background-clip: text;
        color: transparent;
        margin-bottom: 0.5rem;
        text-align: center;
    }

    .error-subtitle {
        font-size: 1.2rem;
        color: #6B3A2A;
        font-weight: 500;
        text-align: center;
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 2px solid #C47D3E30;
    }

    .error-details {
        background-color: #F5ECD7;
        border-radius: 24px;
        padding: 1.25rem;
        margin: 1.5rem 0;
        border-left: 4px solid #C47D3E;
    }

        .error-details p {
            margin-bottom: 0.5rem;
            color: #3D2B1F;
        }

        .error-details strong {
            color: #6B3A2A;
            font-weight: 600;
        }

        .error-details code {
            background-color: #FFFFFF;
            padding: 0.2rem 0.5rem;
            border-radius: 12px;
            color: #EB8B6D;
            font-weight: 600;
            font-size: 0.9rem;
            border: 1px solid #C47D3E30;
        }

    .info-box {
        background: linear-gradient(135deg, #FFF9F0 0%, #FFF5E8 100%);
        border-radius: 24px;
        padding: 1.5rem;
        margin-top: 1.5rem;
        border: 1px solid #C47D3E20;
    }

        .info-box h3 {
            color: #6B3A2A;
            font-size: 1.3rem;
            font-weight: 600;
            margin-bottom: 1rem;
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

            .info-box h3 i {
                color: #EB8B6D;
                font-size: 1.3rem;
            }

        .info-box p {
            color: #3D2B1F;
            line-height: 1.6;
            margin-bottom: 0.75rem;
        }

    .warning-badge {
        display: inline-block;
        background-color: #EB8B6D20;
        color: #B45F3A;
        padding: 0.25rem 0.75rem;
        border-radius: 40px;
        font-size: 0.8rem;
        font-weight: 600;
        margin-right: 0.5rem;
    }

    .action-buttons {
        display: flex;
        gap: 1rem;
        margin-top: 2rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .btn-earth {
        padding: 0.6rem 1.5rem;
        border-radius: 48px;
        font-weight: 600;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        transition: all 0.2s ease;
        border: none;
        cursor: pointer;
    }

    .btn-earth-primary {
        background-color: #6B3A2A;
        color: #F5ECD7;
    }

        .btn-earth-primary:hover {
            background-color: #C47D3E;
            transform: translateY(-2px);
            box-shadow: 0 6px 14px rgba(107, 58, 42, 0.25);
            color: #3D2B1F;
        }

    .btn-earth-secondary {
        background-color: transparent;
        color: #6B3A2A;
        border: 2px solid #6B3A2A;
    }

        .btn-earth-secondary:hover {
            background-color: #6B3A2A;
            color: #F5ECD7;
            transform: translateY(-2px);
        }

    /* Responsive design */
    @@media (max-width: 768px) {
        .error-container {
            margin: 1rem;
            padding: 1.5rem;
        }

        .error-title {
            font-size: 1.8rem;
        }

        .error-subtitle {
            font-size: 1rem;
        }

        .action-buttons {
            flex-direction: column;
        }

        .btn-earth {
            justify-content: center;
        }
    }

    /* Animation-free transitions */
    .error-container, .btn-earth, .info-box {
        transition: all 0.2s ease;
    }
</style>

<div class="error-container">
    <div class="error-icon">
        <i class="bi bi-emoji-frown"></i>
    </div>

    <h1 class="error-title">Oops! Something went wrong</h1>
    <h2 class="error-subtitle">We encountered an error while processing your request</h2>

    @if (Model.ShowRequestId)
    {
        <div class="error-details">
            <p>
                <strong><i class="bi bi-upc-scan"></i> Request ID:</strong>
                <code>@Model.RequestId</code>
            </p>
            <p class="mt-2 mb-0">
                <i class="bi bi-info-circle"></i> Please share this ID with support if the issue persists.
            </p>
        </div>
    }

    <div class="info-box">
        <h3>
            <i class="bi bi-bug"></i>
            Development Mode Information
        </h3>
        <p>
            Swapping to <strong class="warning-badge">Development</strong> environment will display more detailed information about the error that occurred.
        </p>
        <p class="mt-3">
            <i class="bi bi-exclamation-triangle-fill" style="color: #EB8B6D;"></i>
            <strong>The Development environment shouldn't be enabled for deployed applications.</strong>
        </p>
        <p>
            It can result in displaying sensitive information from exceptions to end users.
            For local debugging, enable the <strong>Development</strong> environment by setting the <strong>ASPNETCORE_ENVIRONMENT</strong>
            environment variable to <strong>Development</strong> and restarting the app.
        </p>
    </div>

    <div class="action-buttons">
        <a href="/" class="btn-earth btn-earth-primary">
            <i class="bi bi-house-door"></i> Go to Homepage
        </a>
        <a href="javascript:history.back()" class="btn-earth btn-earth-secondary">
            <i class="bi bi-arrow-left"></i> Go Back
        </a>
    </div>
</div>

<!-- Optional: Log error to console for debugging (no functional changes) -->
<script>
    (function() {
        // Log error details for development (doesn't affect user experience)
        if (@Json.Serialize(Model.ShowRequestId) && '@Model.RequestId' !== '') {
            console.group('🌾 LokaLista Error Details');
            console.log('Request ID:', '@Model.RequestId');
            console.log('Timestamp:', new Date().toISOString());
            console.groupEnd();
        }
    })();
</script>