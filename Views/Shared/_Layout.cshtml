<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Lokalista · Warm & Earthy Dashboard</title>
    <!-- preserve original bootstrap + icons but override design with new color palette (no functional changes) -->
    <link href="/css/bootstrap.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.3.0/font/bootstrap-icons.css">
    
    <!-- CUSTOM EARTHY COLOR PALETTE (Warm & Earthy · Traditional Filipino) 
         #6B3A2A - Buttons, Headers, CTAs
         #C47D3E - Highlights, Hover states
         #4A7C59 - Badges, Success
         #EB8B6D - Puntos rewards, Icons
         #F5ECD7 - Page BG, Cards, Containers
         #3D2B1F - Text, Navbar, Footer
         only transitions and standard CSS, full compatibility -->
    <style>
        /* ----- GLOBAL RESET & BASE (earth tones) ----- */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            background-color: #F5ECD7;   /* Page BG - warm cream */
            font-family: system-ui, 'Segoe UI', 'Roboto', 'Helvetica Neue', sans-serif;
            color: #3D2B1F;              /* primary text color from palette */
            line-height: 1.5;
        }

        /* transition for hovers (no keyframes) */
        a, button, .navbar-nav .nav-link, .btn, .dropdown-item, .card {
            transition: all 0.2s ease-in-out;
        }

        /* ----- NAVBAR (redesigned with earthy colors) ----- */
        .navbar {
            background-color: #3D2B1F !important;   /* Navbar + footer color from palette */
            box-shadow: 0 8px 20px rgba(0, 0, 0, 0.08);
            padding: 0.8rem 1rem;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.6rem;
            letter-spacing: -0.3px;
            background: linear-gradient(135deg, #F5ECD7 20%, #C47D3E 80%);
            background-clip: text;
            -webkit-background-clip: text;
            color: transparent !important;
            position: relative;
        }
        .navbar-brand::after {
            content: "🌾";
            font-size: 1.4rem;
            background: none;
            -webkit-background-clip: unset;
            color: #EB8B6D;
            margin-left: 6px;
            display: inline-block;
        }

        .navbar .nav-link {
            color: #F5ECD7 !important;
            font-weight: 500;
            border-radius: 40px;
            margin: 0 4px;
            padding: 0.5rem 1rem;
        }

        .navbar .nav-link:hover,
        .navbar .nav-link.active {
            background-color: #6B3A2A !important;   /* Buttons/CTAs color on hover */
            color: #F5ECD7 !important;
            transform: translateY(-1px);
        }

        .navbar .nav-link.active {
            background-color: #C47D3E !important;   /* Highlight active page */
            color: #3D2B1F !important;
            font-weight: 600;
        }

        /* dropdown menu styling - earthy integration */
        .dropdown-menu {
            background-color: #FFFFFF;
            border-radius: 20px;
            border: 1px solid #C47D3E40;
            box-shadow: 0 12px 24px rgba(61, 43, 31, 0.1);
            padding: 0.5rem;
        }

        .dropdown-item {
            border-radius: 14px;
            color: #3D2B1F;
            font-weight: 500;
            padding: 0.5rem 1rem;
        }

        .dropdown-item:hover {
            background-color: #C47D3E20;
            color: #6B3A2A;
        }

        /* ----- login partial area (earth style) ----- */
        .navbar .nav-link i, .navbar-text i {
            color: #EB8B6D;           /* Puntos rewards icon style */
        }

        /* custom user greeting */
        .navbar-text {
            color: #F5ECD7 !important;
            font-weight: 500;
        }

        /* ----- BUTTONS & CTAs (global override) ----- */
        .btn-primary, .btn-success, .btn-warning, 
        .btn-outline-primary, .btn-outline-success,
        button[type="submit"], .btn {
            border-radius: 48px !important;
            font-weight: 600;
            padding: 0.5rem 1.5rem;
            transition: 0.2s;
        }

        .btn-primary {
            background-color: #6B3A2A !important;   /* primary buttons */
            border-color: #6B3A2A !important;
            color: #F5ECD7 !important;
        }

        .btn-primary:hover {
            background-color: #C47D3E !important;   /* hover state warm amber */
            border-color: #C47D3E !important;
            transform: translateY(-2px);
            box-shadow: 0 6px 14px rgba(107, 58, 42, 0.25);
        }

        .btn-outline-primary {
            border-color: #6B3A2A;
            color: #6B3A2A;
        }
        .btn-outline-primary:hover {
            background-color: #6B3A2A;
            border-color: #6B3A2A;
            color: #F5ECD7;
        }

        /* success & badges */
        .btn-success, .badge.bg-success {
            background-color: #4A7C59 !important;   /* badges, success */
            border-color: #4A7C59 !important;
        }

        /* card / container panel design (Page BG, Cards, Containers) */
        .card, .container {
            background-color: #FFFFFF;
            border-radius: 28px !important;
            border: none !important;
            box-shadow: 0 8px 20px rgba(61, 43, 31, 0.06);
            transition: all 0.2s;
        }

        .card {
            overflow: hidden;
            margin-bottom: 1.5rem;
        }

        .card:hover {
            transform: translateY(-4px);
            box-shadow: 0 20px 28px -12px rgba(107, 58, 42, 0.15);
        }

        .card-header {
            background-color: #F5ECD7;
            border-bottom: 2px solid #C47D3E30;
            font-weight: 700;
            color: #6B3A2A;
            padding: 1rem 1.5rem;
        }

        /* Badges — success & tags */
        .badge, .tag {
            background-color: #4A7C59 !important;
            color: white !important;
            border-radius: 40px;
            padding: 0.35rem 0.9rem;
            font-weight: 500;
        }

        .badge-warning, .badge-puntos {
            background-color: #EB8B6D !important;
            color: #3D2B1F !important;
        }

        /* icons & puntos reward style */
        i.bi, .reward-icon, .puntos-icon {
            color: #EB8B6D;
        }

        .puntos-text, .puntos-highlight {
            background: #EB8B6D20;
            color: #B45F3A;
            border-radius: 40px;
            padding: 0.2rem 1rem;
            font-weight: 700;
            display: inline-flex;
            align-items: center;
            gap: 6px;
        }

        /* Table warm & earthy */
        .table {
            background-color: white;
            border-radius: 20px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.03);
        }

        .table thead th {
            background-color: #F5ECD7;
            color: #3D2B1F;
            border-bottom: 2px solid #C47D3E;
            font-weight: 600;
        }

        .table tbody tr:hover {
            background-color: #FFF4E6;
        }

        /* Form controls - earthy border */
        .form-control, .form-select {
            border-radius: 24px;
            border: 1px solid #DCCFBC;
            background-color: #FFFFFF;
            padding: 0.6rem 1rem;
            color: #3D2B1F;
        }

        .form-control:focus, .form-select:focus {
            border-color: #C47D3E;
            box-shadow: 0 0 0 3px rgba(196, 125, 62, 0.2);
            outline: none;
        }

        /* Notifications / alerts - warm earthy style */
        .alert {
            border-radius: 24px;
            border-left: 5px solid #4A7C59;
            background-color: #FFFCF5;
            color: #3D2B1F;
            font-weight: 500;
        }

        /* Links inside content */
        a:not(.navbar-brand):not(.nav-link):not(.btn):not(.dropdown-item) {
            color: #6B3A2A;
            text-decoration: none;
            font-weight: 500;
        }

        a:not(.navbar-brand):not(.nav-link):not(.btn):not(.dropdown-item):hover {
            color: #C47D3E;
            text-decoration: underline;
        }

        /* container overrides */
        .container {
            background-color: transparent;
            box-shadow: none;
            padding: 0 1rem;
        }

        /* main container spacing */
        .my-2 {
            margin-top: 1.2rem !important;
            margin-bottom: 1rem !important;
        }

        /* custom hover state for cart count / icons */
        #cartCount {
            background-color: #EB8B6D;
            border-radius: 50px;
            padding: 0.2rem 0.55rem;
            font-size: 0.75rem;
            margin-left: -8px;
            margin-top: -8px;
            font-weight: bold;
            color: #3D2B1F;
        }
        
        /* responsive helper */
        .navbar-toggler {
            background-color: #C47D3E;
            border: none;
        }
        .navbar-toggler-icon {
            filter: brightness(0) invert(1);
        }
        
        /* footer-like elements (if any) */
        footer, .footer {
            background-color: #3D2B1F;
            color: #F5ECD7;
            border-radius: 24px 24px 0 0;
            margin-top: 2rem;
        }

        /* tags, highlights, badges for additional components */
        .highlight-badge {
            background-color: #C47D3E20;
            color: #6B3A2A;
            padding: 0.2rem 0.9rem;
            border-radius: 30px;
            font-size: 0.7rem;
            font-weight: 600;
        }

        /* puntos reward specific custom class */
        .puntos-reward-box {
            background-color: #EB8B6D10;
            border: 1px solid #EB8B6D40;
            border-radius: 40px;
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 0.3rem 1rem;
        }
        
        /* No keyframes used, only standard transitions and states */
        .card, .btn, .nav-link, .dropdown-item {
            transition: all 0.2s ease;
        }

        /* customize scroll */
        ::-webkit-scrollbar {
            width: 8px;
            background: #EBDDCB;
        }
        ::-webkit-scrollbar-thumb {
            background: #C47D3E;
            border-radius: 10px;
        }
        
        /* maintain consistent badge for cart and icons */
        .bi-cart-fill, .bi-person-circle {
            color: #EB8B6D;
        }
    </style>
</head>
<body>
    <!-- REDESIGNED NAVBAR with Earthy/Traditional Filipino palette, but preserves every original link and functionality -->
    <nav class="navbar navbar-expand-lg navbar-dark bg-primary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/Home/Index">Lokalista</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarColor01" aria-controls="navbarColor01" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarColor01">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link active" href="/Home/Index">
                            Home
                            <span class="visually-hidden">(current)</span>
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/Home/Privacy">Privacy</a>
                    </li>
                    @if (User.IsInRole(Roles.Admin.ToString()))
                    {
                        <li class="nav-item">
                            <a class="nav-link" href="/AdminOperations/Dashboard">Dashboard</a>
                        </li>
                       @*  <li class="nav-item">
                          <a class="nav-link" 
                          href="/AdminOperations/AllOrders">Orders</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Stock/Index">Stock</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Genre/Index">Genre</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" href="/Book/Index">Books</a>
                        </li> *@
                    }
                    
                    @*<li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown" href="#" role="button" aria-haspopup="true" aria-expanded="false">Dropdown</a>
                        <div class="dropdown-menu">
                            <a class="dropdown-item" href="#">Action</a>
                            <a class="dropdown-item" href="#">Another action</a>
                            <a class="dropdown-item" href="#">Something else here</a>
                            <div class="dropdown-divider"></div>
                            <a class="dropdown-item" href="#">Separated link</a>
                        </div>
                    </li>*@
                </ul>
                <partial name="_LoginPartial" />

            </div>
        </div>
    </nav>
    
    <!-- main container with page background and cards styling (earth layout) -->
    <div class="container" style="background-color: transparent; padding-top: 1.8rem;">
        <div class="my-2">
            <partial name="_Notifications" />
        </div>
        @RenderBody()
    </div>

    <!-- Scripts: Bootstrap bundle + cart function (preserved, functionality untouched) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0-alpha1/dist/js/bootstrap.bundle.min.js" integrity="sha384-w76AqPfDkMBDXo30jS1Sgez6pr3x5MlQ1ZAGC+nuZB+EYdgRZgiwxhTBTkF7CXvN" crossorigin="anonymous"></script>
    <script>
        loadCartCount();
        async function loadCartCount() {
            try {
                var response = await fetch(`/Cart/GetTotalItemInCart`);
                console.log(response)    
                if (response.status == 200) {
                    var result = await response.json();
                    var cartCountEl = document.getElementById("cartCount");
                    if (cartCountEl) cartCountEl.innerHTML = result;
                }
            }
            catch (err) {
                console.log(err);
            }
        }
    </script>
    @await RenderSectionAsync("Scripts", required: false)
    
    <!-- Additional inline small visual to ensure palette touches Puntos, Tags, Cards, Badges, Hover states in any dynamically rendered content.
         This does not break any functionality but showcases design tokens used across containers. -->
    <style>
        /* ensuring any dynamic elements get punto reward icons & tag styling derived from palette */
        .puntos-badge, .reward-points {
            background-color: #EB8B6D20;
            border-radius: 60px;
            padding: 0.2rem 0.9rem;
            font-weight: bold;
            color: #B45F3A;
        }
        .puntos-badge i, .reward-points i {
            color: #EB8B6D;
        }
        .tag-earth, .genre-tag {
            background-color: #C47D3E20;
            color: #6B3A2A;
            border-radius: 30px;
            padding: 0.2rem 1rem;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-block;
        }
        /* additional sidebar or card hover (CTA accent) */
        .card .btn-link {
            color: #6B3A2A;
        }
        .card .btn-link:hover {
            color: #C47D3E;
        }
        /* strict badge colors for success messages */
        .alert-success, .success-message {
            background-color: #E9F3EC;
            border-left-color: #4A7C59;
            color: #2b4b3a;
        }
        .badge.bg-secondary, .badge.bg-info {
            background-color: #C47D3E !important;
        }
        /* additional icon hover states */
        .navbar-nav .nav-link:hover i {
            color: #EB8B6D;
        }
        /* cart count badge alignment */
        .bi-cart-fill + #cartCount {
            background-color: #EB8B6D;
            color: #3D2B1F;
        }
        /* card design patterns */
        .card-footer {
            background-color: #F5ECD7;
            border-top: 1px solid #E5D5BF;
        }
        /* for any puntos reward specific displays */
        .puntos-reward-highlight {
            color: #EB8B6D;
            font-weight: 800;
        }
        /* hover effects for all cta buttons without keyframes */
        .btn-cta-earth:hover {
            background-color: #C47D3E;
            transform: translateY(-2px);
        }
        /* ensure container bg uses page bg only for wrap, not internal cards */
        .container .card, .container > div > .card {
            background-color: #FFFFFF;
        }
        
        /* additional container style to mirror 'Cards & Containers' from palette */
        .custom-card-container {
            background-color: #FFFFFF;
            border-radius: 28px;
            box-shadow: 0 8px 16px rgba(0, 0, 0, 0.04);
            padding: 1.25rem;
        }
        
        /* handling hover states for all interactive elements */
        .dropdown-menu .dropdown-item:active {
            background-color: #6B3A2A;
            color: #F5ECD7;
        }
    </style>

</body>
</html>

<!-- The layout uses the original provided markup but changes only visual design according to the LokaLista color palette.
     Every original razor syntax such as @if, @RenderBody, @RenderSection, partials, and cart function remains identical.
     No keyframes animation was added anywhere, only transition for hover states. 
     Palette strictly applied to navbar, buttons, badges, icons, containers, cards, tags, puntos elements, and backgrounds. -->